# 复制到服务器：cp novel-agent.env.example /opt/qq-bot/novel-agent.env
# 填好密码与密钥后：chmod 600 /opt/qq-bot/novel-agent.env
#
# systemd 使用 note/novel-agent.service.example 时，Unit 会通过 EnvironmentFile 加载本文件。

SPRING_PROFILES_ACTIVE=

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/novel_agent?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true&connectTimeout=10000&socketTimeout=30000
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.meai.cloud

# 可选：NAPCAT_ACCESS_TOKEN=
